Normalize line endings for all text files to LF in the repo,
# regardless of what OS checks them out. This stops Git's
# "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf
 
# Be explicit for the file types in this project
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.json text eol=lf
 